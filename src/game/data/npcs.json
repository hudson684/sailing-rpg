  "dialogues": {
    "brom_blacksmith": {
      "speaker": "Brom",
      "pages": [
        "Mind the sparks, sailor. The forge runs hot today.",
        "Bring me iron and I'll bring you steel. Fair trade."
      ]
    },
    "mera_vendor": {
      "speaker": "Josie",
      "pages": [
        "Welcome to my shop! I've got a bit of everything — rope, rations, tools, the usual sundries.",
        "Have a look around. If you see something you like, just say the word."
      ]
    },
    "garra_chef": {
      "speaker": "Garra",
      "pages": [
        "Ha! You smell that? Garlic, butter, and a fish that didn't see it coming.",
        "A full belly makes a brave sailor. Come back when you're hungry."
      ]
    },
    "old_salt_fisherman": {
      "speaker": "Old Salt",
      "pages": [
        "Sea's been quiet today. Too quiet, if you ask me.",
        "Cast your line where the gulls dive, friend. They know better than we do."
      ]
    },
    "jory_miner": {
      "speaker": "Jory",
      "pages": [
        "Rock's stubborn today. Wants to stay rock.",
        "Find me a vein of copper and I'll show you what these arms can do."
      ]
    },
    "elin_innkeeper": {
      "speaker": "Elin",
      "pages": [
        "Evenin', traveler. Bed's warm, stew's warmer.",
        "Stay long enough and you'll hear every story this island has to tell."
      ]
    },
    "tomas_farmer": {
      "speaker": "Tomas",
      "pages": [
        "Soil's good this season. Rains came when they were meant to.",
        "If you're heading inland, mind the goats. They've got opinions."
      ]
    },
    "lilan_florist": {
      "speaker": "Lilan",
      "pages": [
        "Careful — that one bites back if you're rough with it.",
        "A bouquet for someone special? Or just for yourself? Both are good answers."
      ]
    },
    "odderf_frog": {
      "speaker": "Odderf",
      "pages": [
        "*ribbit* …oh. You're tall. Hello, tall one.",
        "I sit by the water. The water sits by me. We have an arrangement."
      ]
    },
    "steve": {
      "speaker": "Steve",
      "pages": [
        "Aye. Name's Steve.",
        "Don't let the hat fool you. I'm mostly retired."
      ]
    }
  }
}
