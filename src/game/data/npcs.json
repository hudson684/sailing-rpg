  "dialogues": {
    "brom_blacksmith": {
      "speaker": "Brom",
      "pages": [
        "Well met, sailor. The forge burns hot today.",
        "Bring me iron and coal, and I'll see your blade keeps its edge at sea.",
        "A good hammer beats a bad storm — every time."
      ]
    },
    "mera_vendor": {
      "speaker": "Mera",
      "pages": [
        "Welcome to my stall! Rope, hardtack, lantern oil — I've got what a traveller needs.",
        "Coin talks louder than weather, friend. What'll it be?"
      ]
    },
    "finn_fish_vendor": {
      "speaker": "Finn",
      "pages": [
        "Fresh catch! Pulled 'em in this morning, still arguing with the net.",
        "A cod a day keeps the scurvy away. Old sailor's wisdom."
      ]
    },
    "old_salt_fisherman": {
      "speaker": "Old Salt",
      "pages": [
        "Ahoy. Weather's holding, but I don't trust that sky northward.",
        "I once hooked a creature bigger than my boat. Tell you the tale another time."
      ]
    },
    "alric_wizard": {
      "speaker": "Alric",
      "pages": [
        "Ah — a traveller with salt on their boots. The sea has given you passage.",
        "Mind the isles to the east. Not all of them are on any chart.",
        "When the stars over the cove burn blue, return to me. There is work afoot."
      ]
    },
    "tessa_skill_master": {
      "speaker": "Tessa",
      "pages": [
        "You carry yourself like someone who's learned a thing or two.",
        "Train with me when you're ready. A sharp mind beats a sharp sword most days."
      ]
    },
    "jory_villager": {
      "speaker": "Jory",
      "pages": [
        "Morning! Just on my rounds. The village never sleeps, nor do its errands.",
        "If you see my goat, tell her I'm not angry. Just disappointed."
      ]
    },
    "elin_villager": {
      "speaker": "Elin",
      "pages": [
        "Oh — hello! I didn't see you there.",
        "My father says strangers bring either news or trouble. Which are you?"
      ]
    }
  }
}
